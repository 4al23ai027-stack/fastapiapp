# Auto-detect text files and normalize to LF in the repository
* text=auto

# Ensure common text files use LF in the repo
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf

# Do not attempt to normalize binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Keep node_modules as-is (we will ignore it)
frontend/node_modules/** -text
node_modules/** -text
